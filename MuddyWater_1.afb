                    "name",
                    "CVE-2025-5777 (Citrix NetScaler ADC / Gateway)"
                ],
                [
                    "description",
                    "When configured as a VPN virtual server or NetScaler Gateway, an unauthenticated attacker can send crafted HTTP POST requests to steal active session tokens out of memory. This allows them to hijack user sessions and drop straight into the network, bypassing MFA entirely."
                ]
            ],
